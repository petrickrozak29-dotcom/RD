generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== User Management Models ====================

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String
  name         String
  avatar       String?
  bio          String?
  role         String  @default("USER") // "USER" | "ADMIN"

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastLogin DateTime?

  isVerified Boolean @default(false)
  isActive   Boolean @default(true) // soft delete flag

  // Relationships
  preferences      UserPreferences?
  locations        UserLocation[]
  savedItineraries SavedItinerary[]
  submissions      Submission[]     @relation("UserSubmissions")
  notifications    Notification[]

  @@index([email])
  @@index([role])
}

model UserPreferences {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  interests          String @default("") // store as JSON string for SQLite
  budgetLevel        String @default("moderate") // 'budget' | 'moderate' | 'premium'
  mobilityLevel      Int    @default(5) // 1-10 scale
  maxSpendPerDay     Float  @default(0)
  distancePreference Float  @default(5) // km
  language           String @default("id")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserLocation {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  latitude  Float
  longitude Float
  accuracy  Float?
  altitude  Float?
  speed     Float?

  timestamp DateTime
  source    String   @default("gps") // 'gps' | 'wifi' | 'manual'
  deviceId  String?

  isDeleted Boolean  @default(false) // soft delete flag
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, timestamp])
}

model SavedItinerary {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  description String?
  items       String // store itinerary array as JSON string

  duration           Int
  totalDistance      Float
  totalEstimatedCost Float

  isCompleted Boolean   @default(false)
  completedAt DateTime?

  rating   Int?
  feedback String?

  isDeleted Boolean @default(false) // soft delete flag

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ==================== Existing Content Models ====================

model Tourism {
  id          String @id @default(cuid())
  name        String
  description String
  latitude    Float
  longitude   Float
  image       String
  category    String

  @@index([category])
  @@index([latitude, longitude])
}

model Culinary {
  id          String @id @default(cuid())
  name        String
  description String
  priceRange  String
  image       String
}

model Event {
  id       String   @id @default(cuid())
  title    String
  date     DateTime
  location String
  image    String
}

model Article {
  id       String @id @default(cuid())
  title    String
  content  String
  category String
}

// ==================== Dynamic Features Models ====================

model FeatureToggle {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "Event", "Wisata", "Kuliner", "Smart Magelang"
  isActive    Boolean  @default(true)
  description String?
  updatedAt   DateTime @updatedAt
}

model Category {
  id          String   @id @default(cuid())
  name        String
  featureType String // e.g., "EVENT", "WISATA", "KULINER", "SMART_MAGELANG"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions           Submission[]
  smartMagelangContents SmartMagelangContent[]

  @@unique([name, featureType])
  @@index([featureType])
}

model Submission {
  id          String @id @default(cuid())
  title       String
  description String
  featureType String // "EVENT", "WISATA", "KULINER"
  status      String @default("PENDING") // "PENDING", "APPROVED", "REJECTED"

  // Relations
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  submittedById String?
  submittedBy   User?   @relation("UserSubmissions", fields: [submittedById], references: [id], onDelete: SetNull)

  // Location Data
  location  String?
  latitude  Float?
  longitude Float?

  // Additional Data
  image      String?
  link       String?
  priceRange String?
  date       DateTime?
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([featureType])
  @@index([status])
  @@index([categoryId])
  @@index([submittedById])
}

model SmartMagelangContent {
  id          String  @id @default(cuid())
  title       String
  description String
  sourceUrl   String?
  image       String?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
}

// Notifications for user and developer/admin alerts
model Notification {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  message   String
  payload   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}
